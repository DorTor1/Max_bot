# MAX Bot API (панель интеграции)
BOT_TOKEN=your_bot_token_here

# Режим: polling | webhook
BOT_MODE=polling

# Webhook (prod)
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_PATH=/max/webhook
WEBHOOK_SECRET=change_me_min_5_chars
WEBHOOK_PUBLIC_URL=https://example.com/max/webhook

# PostgreSQL
DATABASE_URL=postgresql+psycopg2://passbot:passbot@localhost:5432/passbot

# Юридический блок
CONSENT_VERSION=2026-05-1

# Первичные тех. админы (MAX user_id через запятую)
TECH_ADMIN_MAX_IDS=

# Логирование
LOG_LEVEL=INFO
