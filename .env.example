# mock — MSW; real — только реальный бэкенд (без MSW)
VITE_API_MODE=mock
# Базовый URL API (для real). В mock можно оставить пустым — запросы к origin
VITE_API_BASE_URL=
# Роль в мок-сессии (сервер в проде определяет сам; не для прод-логики)
VITE_MOCK_ROLE=initiator
VITE_MOCK_USER_ID=user-demo-1
VITE_MOCK_USER_NAME=Иван Инициатор
